generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Identity model (ADR-002, AUTH-01): staff and client-rep principals in one
// SYSTEM table — staff users have no client, login precedes client scope, so
// auth_users is app_staff-only and deliberately NOT client-scoped/RLS'd.
model AuthUser {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String        @unique
  passwordHash  String        @map("password_hash")
  principalType PrincipalType @map("principal_type")
  role          Role          @default(read_only)
  clientId      String?       @map("client_id") @db.Uuid
  status        UserStatus    @default(active)
  mfaSecret     String?       @map("mfa_secret")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("auth_users")
}

enum PrincipalType {
  staff
  client_rep
}

// The nine roles from the frozen architecture's permission matrix.
// Least-privilege default: read_only.
enum Role {
  system_admin
  company_admin
  recruiter
  hr_officer
  gro_officer
  finance
  read_only
  client_admin
  client_user
}

enum UserStatus {
  active
  disabled
}

// Pattern exemplar for client-scoped tables (ADR-001). Every client-owned
// table carries client_id and ships RLS policies in its migration — see the
// checklist in src/modules/README.md. This table exists to keep the RLS
// wiring continuously tested until the first real module table lands.
model CoreScopeCheck {
  id       Int    @id @default(autoincrement())
  clientId String @map("client_id") @db.Uuid
  note     String

  @@map("core_scope_check")
}

// Append-only audit trail (AUDIT-01; architecture.md Shared Modules, ADR-004).
// SYSTEM table: only System/Company Admin hold `audit.read` (permission
// matrix) — NO client role reads it, so like auth_users it is app_staff-read
// and deliberately NOT RLS-read-scoped. No UPDATE/DELETE grants to ANY role:
// append-only is enforced at the GRANT level (see the migration), not by
// convention. `client_id` is nullable (system actions have no client) and is
// DATA for filtering, not an RLS scope key. Grants for the client-rep write
// path (app_client INSERT + its RLS WITH CHECK) arrive in AUDIT-02, when
// client-rep mutations are wired and testable.
model AuditEntry {
  id        BigInt   @id @default(autoincrement())
  actorId   String?  @map("actor_id") @db.Uuid
  actorRole String?  @map("actor_role")
  clientId  String?  @map("client_id") @db.Uuid
  resource  String
  action    String
  before    Json?    @db.JsonB
  after     Json?    @db.JsonB
  requestId String?  @map("request_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([resource, action])
  @@index([clientId])
  @@index([createdAt])
  @@map("aud_entries")
}

// System-level configuration overrides (CONF-01; ACTION-PLAN 2.4). The SYSTEM
// level of the three-level settings model (system → client → user precedence).
// Deployment-wide and managed by System Admin, so — like auth_users — it is a
// SYSTEM table with NO RLS (not client-owned data). The setting CATALOG
// (permitted levels + validation + coded defaults) lives in code
// (modules/configuration/domain/catalog.ts); this table holds only overrides of
// a coded default. Per-client (cfg_client_settings) / per-user
// (cfg_user_settings) tables arrive in CONF-02/03.
model SystemSetting {
  key       String   @id
  value     Json     @db.JsonB
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cfg_system_settings")
}

// Client-company registry (CLIENT-01; ADR-002 isolation boundary). This table
// ORIGINATES client_id: every client-owned row elsewhere references one of
// these ids. It is itself client-scoped, but UNLIKE the boilerplate pattern
// the RLS scope key is the row's OWN primary key (a client IS the client) —
// there is no denormalized client_id column. Staff have full access; a
// client-rep may read ONLY its own company row (SELECT), never write. See the
// migration for grants + policies. Bilingual names per ADR-005.
model Client {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nameAr    String       @map("name_ar")
  nameEn    String       @map("name_en")
  status    ClientStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("cli_clients")
}

enum ClientStatus {
  active
  inactive
}

// Employee record (EMP-01; ACTION-PLAN 3.1, built from docs/FIELD-MAPPING.md).
// The domain core. Client-scoped via a STANDARD client_id column (RLS keys on
// it — unlike cli_clients' PK-scoped variant). All three sensitivity groups
// (core / salary / govdata) live as columns on ONE table; field-level
// authorization (redacting salary/govdata per capability) is enforced at the
// API layer in EMP-02, not by separate tables. Dates are stored Gregorian UTC
// and rendered Hijri via @hr/dates (ADR-005). v1 is manual entry: everything
// except identity/employment basics is nullable.
model Employee {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId String @map("client_id") @db.Uuid

  // --- core (employee.*) ---
  nameAr                  String           @map("name_ar")
  nameEn                  String           @map("name_en")
  nationality             String // ISO 3166-1 alpha-2
  gender                  Gender?
  dateOfBirth             DateTime?         @map("date_of_birth") @db.Date
  jobTitleAr              String?           @map("job_title_ar")
  jobTitleEn              String?           @map("job_title_en")
  department              String?
  hireDate                DateTime?         @map("hire_date") @db.Date
  employmentStatus        EmploymentStatus @default(active) @map("employment_status")
  contractType            ContractType     @map("contract_type")
  contractEndDate         DateTime?         @map("contract_end_date") @db.Date
  countsTowardSaudization Boolean?          @map("counts_toward_saudization")

  // --- salary (salary.*) ---
  currency               String   @default("SAR")
  basicSalary            Decimal? @map("basic_salary") @db.Decimal(12, 2)
  housingAllowance       Decimal? @map("housing_allowance") @db.Decimal(12, 2)
  transportAllowance     Decimal? @map("transport_allowance") @db.Decimal(12, 2)
  otherAllowances        Decimal? @map("other_allowances") @db.Decimal(12, 2)
  gosiWage               Decimal? @map("gosi_wage") @db.Decimal(12, 2)
  gosiContributionBasis  GosiContributionBasis? @map("gosi_contribution_basis")
  bankIban               String?  @map("bank_iban")
  wpsStatus              WpsStatus? @map("wps_status")

  // --- govdata:id — identifiers (staff only) ---
  iqamaNumber            String? @map("iqama_number")
  nationalId             String? @map("national_id")
  borderNumber           String? @map("border_number")
  passportNumber         String? @map("passport_number")
  workPermitNumber       String? @map("work_permit_number")
  gosiRegistrationNumber String? @map("gosi_registration_number")
  absherServiceRef       String? @map("absher_service_ref")

  // --- govdata:status — expiry/status (client-rep may see own) ---
  iqamaExpiry            DateTime?               @map("iqama_expiry") @db.Date
  passportExpiry         DateTime?               @map("passport_expiry") @db.Date
  workPermitExpiry       DateTime?               @map("work_permit_expiry") @db.Date
  exitReentryStatus      ExitReentryStatus?      @map("exit_reentry_status")
  exitReentryExpiry      DateTime?               @map("exit_reentry_expiry") @db.Date
  gosiRegistrationStatus GosiRegistrationStatus? @map("gosi_registration_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@map("emp_employees")
}

enum Gender {
  male
  female
}

enum EmploymentStatus {
  active
  on_leave
  suspended
  terminated
}

enum ContractType {
  unlimited
  fixed_term
  part_time
  temporary
  seasonal
}

enum GosiContributionBasis {
  basic
  basic_plus_housing
}

enum WpsStatus {
  compliant
  pending
  non_compliant
}

enum ExitReentryStatus {
  none
  single
  multiple
}

enum GosiRegistrationStatus {
  registered
  pending
  not_registered
}
