{
  "name": "@hr/api",
  "version": "0.0.1",
  "private": true,
  "description": "HR Operations Platform API — NestJS modular monolith",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "CHECKPOINT_DISABLE=1 prisma migrate dev",
    "db:deploy": "CHECKPOINT_DISABLE=1 prisma migrate deploy",
    "db:generate": "CHECKPOINT_DISABLE=1 prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hr/contracts": "workspace:*",
    "@hr/dates": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bullmq": "^5.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.45.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "otplib": "^13.4.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@hr/config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.10.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.0.0"
  }
}
