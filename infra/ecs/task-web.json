{
  "family": "hr-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::075483720704:role/hr-task-execution",
  "taskRoleArn": "arn:aws:iam::075483720704:role/hr-task-role",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "IMAGE_PLACEHOLDER",
      "essential": true,
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/hr/web",
          "awslogs-region": "me-central-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ]
}
