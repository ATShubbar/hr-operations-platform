# Local development connection strings (docker-compose.yml).
# Copy to .env — .env is gitignored; never commit real credentials.

# Postgres (host port 5433 — 5432 is taken by another local project)
DATABASE_URL="postgresql://hr:hr_local_dev@localhost:5433/hr_platform"

# Redis (host port 6380 — 6379 is taken by another local project)
REDIS_URL="redis://localhost:6380"

# API
PORT=3001
