# Local development connection strings (docker-compose.yml).
# Copy to .env — .env is gitignored; never commit real credentials.

# Postgres (host port 5433 — 5432 is taken by another local project)
# Owner connection — used by prisma migrate ONLY, never by the running app:
DATABASE_URL="postgresql://hr:hr_local_dev@localhost:5433/hr_platform"
# App connections (ADR-001 two-role pattern; dev passwords — production
# rotates them at provisioning):
STAFF_DATABASE_URL="postgresql://app_staff:app_staff_dev_pw@localhost:5433/hr_platform"
CLIENT_DATABASE_URL="postgresql://app_client:app_client_dev_pw@localhost:5433/hr_platform"

# Redis (host port 6380 — 6379 is taken by another local project)
REDIS_URL="redis://localhost:6380"

# S3-compatible object storage (STOR-01) — MinIO locally (host port 9002).
# The adapter is endpoint-configurable: production points STORAGE_ENDPOINT at the
# KSA-hosted object store (ADR-006) and rotates the keys at provisioning.
STORAGE_ENDPOINT="http://localhost:9002"
STORAGE_REGION="us-east-1"
STORAGE_BUCKET="hr-documents"
STORAGE_ACCESS_KEY="hr_minio"
STORAGE_SECRET_KEY="hr_minio_dev_pw"

# API
PORT=3001
